# ─────────────────────────────────────────────
#  SquadMind – Environment Variables Template
#  Copy to .env and fill in your values
# ─────────────────────────────────────────────

# Application
APP_NAME="SquadMind"
APP_ENV="development"          # development | staging | production
APP_VERSION="1.0.0"
DEBUG=true
LOG_LEVEL="INFO"

# API
API_V1_PREFIX="/api/v1"
SECRET_KEY="CHANGE-ME-USE-OPENSSL-RAND-HEX-32"
ACCESS_TOKEN_EXPIRE_MINUTES=1440       # 24 hours
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM="HS256"

# PostgreSQL
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_DB="squadmind"
POSTGRES_USER="squadmind_user"
POSTGRES_PASSWORD="your-secure-password"
DATABASE_URL="postgresql+asyncpg://squadmind_user:your-secure-password@localhost:5432/squadmind"
DATABASE_URL_SYNC="postgresql://squadmind_user:your-secure-password@localhost:5432/squadmind"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0
REDIS_URL="redis://localhost:6379/0"

# Celery
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"

# Squad API (HabariPay)
SQUAD_BASE_URL="https://sandbox-api-d.squadco.com"
SQUAD_SECRET_KEY="your-squad-secret-key"
SQUAD_PUBLIC_KEY="your-squad-public-key"
SQUAD_WEBHOOK_SECRET="your-webhook-secret"

# OpenAI
OPENAI_API_KEY="sk-your-openai-key"
OPENAI_MODEL="gpt-4o-mini"

# Twilio (WhatsApp / SMS)
TWILIO_ACCOUNT_SID="your-twilio-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"
TWILIO_SMS_NUMBER="+1234567890"

# SendGrid (Email)
SENDGRID_API_KEY="SG.your-sendgrid-key"
SENDGRID_FROM_EMAIL="noreply@squadmind.ai"
SENDGRID_FROM_NAME="SquadMind AI"

# CORS
CORS_ORIGINS="http://localhost:3000,http://localhost:3001,https://squadmind.ai"

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Fraud Detection Thresholds
FRAUD_LARGE_TRANSACTION_THRESHOLD=500000   # NGN 500,000
FRAUD_VELOCITY_WINDOW_MINUTES=60
FRAUD_VELOCITY_MAX_COUNT=10
FRAUD_NIGHT_HOUR_START=23
FRAUD_NIGHT_HOUR_END=5

# Forecasting
FORECAST_DAYS_AHEAD=30
FORECAST_LOOKBACK_DAYS=90
